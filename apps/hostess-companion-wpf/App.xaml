<Application x:Class="HostessCompanion.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="Brush.Background" Color="#F4F5F7"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Brush.Border" Color="#D8DCE2"/>
    <SolidColorBrush x:Key="Brush.Text" Color="#1F2328"/>
    <SolidColorBrush x:Key="Brush.Muted" Color="#606975"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="#0F766E"/>
    <SolidColorBrush x:Key="Brush.Warning" Color="#9A6700"/>
    <SolidColorBrush x:Key="Brush.Error" Color="#B42318"/>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibility"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style TargetType="Button">
      <Setter Property="Padding" Value="12,7"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
      <Setter Property="Foreground" Value="{StaticResource Brush.Text}"/>
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
      <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="GridLinesVisibility" Value="Horizontal"/>
      <Setter Property="HeadersVisibility" Value="Column"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="CanUserDeleteRows" Value="False"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="RowHeight" Value="32"/>
      <Setter Property="ColumnHeaderHeight" Value="32"/>
    </Style>
  </Application.Resources>
</Application>
