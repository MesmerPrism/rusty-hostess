<Window x:Class="HostessCompanion.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hostess Companion"
        Width="1160"
        Height="720"
        MinWidth="900"
        MinHeight="560"
        Background="{StaticResource Brush.Background}">
  <DockPanel>
    <Border DockPanel.Dock="Top"
            Height="52"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Border}"
            BorderThickness="0,0,0,1">
      <Grid Margin="20,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Hostess Companion"
                   FontSize="18"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
          <TextBlock Text="{Binding ReportStatusLabel}"
                     VerticalAlignment="Center"
                     Foreground="{Binding ReportStatusBrush}"/>
          <TextBlock Text="  /  "
                     VerticalAlignment="Center"
                     Foreground="{StaticResource Brush.Muted}"/>
          <TextBlock Text="{Binding CatalogStatusLabel}"
                     VerticalAlignment="Center"
                     Foreground="{Binding CatalogStatusBrush}"/>
          <TextBlock Text="  /  "
                     VerticalAlignment="Center"
                     Foreground="{StaticResource Brush.Muted}"/>
          <TextBlock Text="{Binding ConnectivityStatusLabel}"
                     VerticalAlignment="Center"
                     Foreground="{Binding ConnectivityStatusBrush}"/>
        </StackPanel>
      </Grid>
    </Border>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="240"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="320"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{StaticResource Brush.Surface}"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="0,0,1,0">
        <ListBox ItemsSource="{Binding NavigationItems}"
                 SelectedItem="{Binding SelectedNavigationItem}"
                 DisplayMemberPath="Title"
                 BorderThickness="0"
                 Margin="0,12,0,0">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding" Value="20,10"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Border>

      <Grid Grid.Column="1" Margin="20">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding PageTitle}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <Border Grid.Row="1"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1"
                Padding="12"
                Margin="0,0,0,12">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="120"/>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Serial"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource Brush.Muted}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Serial, UpdateSourceTrigger=PropertyChanged}"/>
            <CheckBox Grid.Column="2"
                      Content="Quest profile"
                      IsChecked="{Binding UseQuestProfile}"
                      VerticalAlignment="Center"
                      Margin="16,0,0,0"/>
            <CheckBox Grid.Column="3"
                      Content="Probe broker"
                      IsChecked="{Binding CheckBroker}"
                      VerticalAlignment="Center"
                      Margin="16,0,0,0"/>
            <Button Grid.Column="5"
                    Content="{Binding RefreshButtonLabel}"
                    Command="{Binding RefreshCommand}"/>
            <Button Grid.Column="6"
                    Content="{Binding LoadSessionHistoryButtonLabel}"
                    Command="{Binding LoadSessionHistoryCommand}"
                    Margin="8,0,0,0"
                    ToolTip="Load saved companion session reports"
                    Visibility="{Binding IsSessionSelected, Converter={StaticResource BooleanToVisibility}}"/>
            <Button Grid.Column="7"
                    Content="{Binding LoadSelectedSessionButtonLabel}"
                    Command="{Binding LoadSelectedSessionCommand}"
                    Margin="8,0,0,0"
                    ToolTip="Load the selected saved session"
                    Visibility="{Binding IsSessionSelected, Converter={StaticResource BooleanToVisibility}}"/>
            <Button Grid.Column="8"
                    Content="{Binding RunSessionButtonLabel}"
                    Command="{Binding RunSessionCommand}"
                    Margin="8,0,0,0"
                    Visibility="{Binding IsSessionSelected, Converter={StaticResource BooleanToVisibility}}"/>
            <Button Grid.Column="9"
                    Content="{Binding RunProbeButtonLabel}"
                    Command="{Binding RunProbeCommand}"
                    Margin="8,0,0,0"
                    Visibility="{Binding IsCommandsSelected, Converter={StaticResource BooleanToVisibility}}"/>
          </Grid>
        </Border>

        <Grid Grid.Row="2">
          <DataGrid ItemsSource="{Binding Checks}"
                    SelectedItem="{Binding SelectedCheck}"
                    AutoGenerateColumns="False"
                    Visibility="{Binding IsReadinessSelected, Converter={StaticResource BooleanToVisibility}}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120"/>
              <DataGridTextColumn Header="Check" Binding="{Binding Title}" Width="220"/>
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
              <DataGridCheckBoxColumn Header="Required" Binding="{Binding Required}" Width="80"/>
              <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>

          <DataGrid ItemsSource="{Binding DeviceChecks}"
                    SelectedItem="{Binding SelectedDeviceCheck}"
                    AutoGenerateColumns="False"
                    Visibility="{Binding IsDevicesSelected, Converter={StaticResource BooleanToVisibility}}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="110"/>
              <DataGridTextColumn Header="Condition" Binding="{Binding Title}" Width="220"/>
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
              <DataGridCheckBoxColumn Header="Required" Binding="{Binding Required}" Width="80"/>
              <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>

          <Grid Visibility="{Binding IsConnectivitySelected, Converter={StaticResource BooleanToVisibility}}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="8"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="1"
                    Padding="12">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="6"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="6"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="6"/>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="10"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="76"/>
                  <ColumnDefinition Width="110"/>
                  <ColumnDefinition Width="70"/>
                  <ColumnDefinition Width="90"/>
                  <ColumnDefinition Width="70"/>
                  <ColumnDefinition Width="112"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Program"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Muted}"/>
                <TextBox Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Text="{Binding ConnectivityProgram, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Executable allowed by the scoped Windows Firewall rule"/>

                <TextBlock Grid.Row="2"
                           Text="Port"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Muted}"/>
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Text="{Binding ConnectivityPort, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="2"
                           Text="Protocol"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="{StaticResource Brush.Muted}"/>
                <TextBox Grid.Row="2"
                         Grid.Column="3"
                         Text="{Binding ConnectivityProtocol, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="4"
                           Text="Profile"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="{StaticResource Brush.Muted}"/>
                <TextBox Grid.Row="2"
                         Grid.Column="5"
                         Text="{Binding ConnectivityProfile, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4"
                           Text="Remote"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Muted}"/>
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Text="{Binding ConnectivityRemoteAddress, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="6"
                           Text="Rule"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Brush.Muted}"/>
                <TextBox Grid.Row="6"
                         Grid.Column="1"
                         Grid.ColumnSpan="5"
                         Text="{Binding ConnectivityRuleName, UpdateSourceTrigger=PropertyChanged}"/>

                <WrapPanel Grid.Row="8"
                           Grid.ColumnSpan="6">
                  <Button Content="{Binding PlanFirewallRuleButtonLabel}"
                          Command="{Binding PlanFirewallRuleCommand}"
                          ToolTip="Write a firewall rule plan artifact"/>
                  <Button Content="{Binding ApplyFirewallRuleButtonLabel}"
                          Command="{Binding ApplyFirewallRuleCommand}"
                          Margin="8,0,0,0"
                          ToolTip="Apply the planned firewall rule with Windows administrator approval"/>
                  <Button Content="{Binding VerifyFirewallRuleButtonLabel}"
                          Command="{Binding VerifyFirewallRuleCommand}"
                          Margin="8,0,0,0"
                          ToolTip="Verify the product firewall rule without running the QCL data probe"/>
                  <Button Content="{Binding VerifyConnectivityButtonLabel}"
                          Command="{Binding VerifyConnectivityCommand}"
                          Margin="8,0,0,0"
                          ToolTip="Run QCL-010 for TCP or QCL-080 for UDP against the headset"/>
                  <Button Content="{Binding RunConnectivitySuiteButtonLabel}"
                          Command="{Binding RunConnectivitySuiteCommand}"
                          Margin="8,0,0,0"
                          ToolTip="Run the fixture install/environment/protocol suite and render grouped results"/>
                  <Button Content="{Binding RemoveFirewallRuleButtonLabel}"
                          Command="{Binding RemoveFirewallRuleCommand}"
                          Margin="8,0,0,0"
                          ToolTip="Remove the selected firewall rule with Windows administrator approval"/>
                  <TextBlock Text="{Binding ConnectivityStatusLabel}"
                             Foreground="{Binding ConnectivityStatusBrush}"
                             VerticalAlignment="Center"
                             Margin="16,0,0,0"/>
                </WrapPanel>
              </Grid>
            </Border>

            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding ConnectivityChecks}"
                      SelectedItem="{Binding SelectedConnectivityCheck}"
                      AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Check" Binding="{Binding Name}" Width="230"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="Evidence" Binding="{Binding Evidence}" Width="*"/>
                <DataGridTextColumn Header="Issues" Binding="{Binding IssueCodes}" Width="190"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>

          <Grid Visibility="{Binding IsSessionSelected, Converter={StaticResource BooleanToVisibility}}">
            <Grid.RowDefinitions>
              <RowDefinition Height="150"/>
              <RowDefinition Height="8"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="8"/>
              <RowDefinition Height="160"/>
            </Grid.RowDefinitions>
            <DataGrid ItemsSource="{Binding SessionHistory}"
                      SelectedItem="{Binding SelectedSessionHistoryEntry}"
                      AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Started" Binding="{Binding StartedAtLabel}" Width="140"/>
                <DataGridTextColumn Header="Session" Binding="{Binding SessionId}" Width="220"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="Profile" Binding="{Binding Profile}" Width="150"/>
                <DataGridTextColumn Header="Summary" Binding="{Binding SummaryLine}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
            <GridSplitter Grid.Row="1"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"/>
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding SessionPhases}"
                      SelectedItem="{Binding SelectedSessionPhase}"
                      AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Phase" Binding="{Binding Title}" Width="190"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                <DataGridCheckBoxColumn Header="Required" Binding="{Binding Required}" Width="80"/>
                <DataGridTextColumn Header="Actions" Binding="{Binding ActionCount}" Width="80"/>
                <DataGridTextColumn Header="Artifacts" Binding="{Binding ArtifactCount}" Width="80"/>
                <DataGridTextColumn Header="Issues" Binding="{Binding IssueCount}" Width="80"/>
                <DataGridTextColumn Header="Detail" Binding="{Binding StatusLine}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
            <GridSplitter Grid.Row="3"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"/>
            <DataGrid Grid.Row="4"
                      ItemsSource="{Binding SessionArtifacts}"
                      SelectedItem="{Binding SelectedSessionArtifact}"
                      AutoGenerateColumns="False">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="180"/>
                <DataGridTextColumn Header="Artifact" Binding="{Binding ArtifactId}" Width="220"/>
                <DataGridTextColumn Header="Validation" Binding="{Binding ValidationStatus}" Width="90"/>
                <DataGridTextColumn Header="Schema" Binding="{Binding Schema}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>

          <DataGrid ItemsSource="{Binding Transports}"
                    SelectedItem="{Binding SelectedTransport}"
                    AutoGenerateColumns="False"
                    Visibility="{Binding IsTransportsSelected, Converter={StaticResource BooleanToVisibility}}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Family" Binding="{Binding Family}" Width="130"/>
              <DataGridTextColumn Header="Transport" Binding="{Binding Title}" Width="180"/>
              <DataGridTextColumn Header="Plane" Binding="{Binding Plane}" Width="90"/>
              <DataGridTextColumn Header="Delivery" Binding="{Binding Delivery}" Width="140"/>
              <DataGridTextColumn Header="Payload" Binding="{Binding PayloadRate}" Width="130"/>
              <DataGridTextColumn Header="Evidence stages" Binding="{Binding EvidenceStages}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>

          <DataGrid ItemsSource="{Binding CommandStages}"
                    SelectedItem="{Binding SelectedCommandStage}"
                    AutoGenerateColumns="False"
                    Visibility="{Binding IsCommandsSelected, Converter={StaticResource BooleanToVisibility}}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Stage" Binding="{Binding Stage}" Width="170"/>
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
              <DataGridTextColumn Header="Observed ms" Binding="{Binding ObservedAtMs}" Width="120"/>
              <DataGridTextColumn Header="Evidence" Binding="{Binding EvidenceRefs}" Width="*"/>
              <DataGridTextColumn Header="Issues" Binding="{Binding IssueCodes}" Width="180"/>
            </DataGrid.Columns>
          </DataGrid>

          <DataGrid ItemsSource="{Binding EvidenceArtifacts}"
                    SelectedItem="{Binding SelectedEvidenceArtifact}"
                    AutoGenerateColumns="False"
                    Visibility="{Binding IsEvidenceSelected, Converter={StaticResource BooleanToVisibility}}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Module" Binding="{Binding ModuleTitle}" Width="180"/>
              <DataGridTextColumn Header="Artifact" Binding="{Binding ArtifactId}" Width="180"/>
              <DataGridTextColumn Header="Schema" Binding="{Binding Schema}" Width="*"/>
              <DataGridTextColumn Header="Owner" Binding="{Binding OwnerLane}" Width="90"/>
              <DataGridCheckBoxColumn Header="Redact" Binding="{Binding RedactionRequired}" Width="70"/>
            </DataGrid.Columns>
          </DataGrid>

          <DataGrid ItemsSource="{Binding Workspaces}"
                    SelectedItem="{Binding SelectedWorkspace}"
                    AutoGenerateColumns="False"
                    Visibility="{Binding IsWorkspacesSelected, Converter={StaticResource BooleanToVisibility}}">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Workspace" Binding="{Binding Title}" Width="220"/>
              <DataGridTextColumn Header="Modules" Binding="{Binding ModuleCount}" Width="80"/>
              <DataGridTextColumn Header="Required" Binding="{Binding RequiredCount}" Width="80"/>
              <DataGridTextColumn Header="Prominent" Binding="{Binding ProminentCount}" Width="90"/>
              <DataGridTextColumn Header="Frontends" Binding="{Binding SupportedFrontends}" Width="140"/>
              <DataGridTextColumn Header="Sensitivity" Binding="{Binding Sensitivity}" Width="130"/>
              <DataGridTextColumn Header="Source" Binding="{Binding SourcePath}" Width="*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>

        <TextBlock Grid.Row="3"
                   Text="{Binding SummaryLabel}"
                   Margin="0,10,0,0"
                   Foreground="{StaticResource Brush.Muted}"/>
      </Grid>

      <Border Grid.Column="2"
              Background="{StaticResource Brush.Surface}"
              BorderBrush="{StaticResource Brush.Border}"
              BorderThickness="1,0,0,0"
              Padding="16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="Details"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Margin="0,0,0,12"/>
          <TextBlock Grid.Row="1"
                     Text="{Binding SelectedDetailTitle}"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"/>
          <TextBlock Grid.Row="2"
                     Text="{Binding SelectedDetailStatusLine}"
                     Foreground="{Binding SelectedDetailBrush}"
                     Margin="0,8,0,12"
                     TextWrapping="Wrap"/>
          <TextBox Grid.Row="3"
                   Text="{Binding SelectedDetailText, Mode=OneWay}"
                   TextWrapping="Wrap"
                   AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto"
                   IsReadOnly="True"/>
        </Grid>
      </Border>
    </Grid>
  </DockPanel>
</Window>
